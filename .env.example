# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# Finnhub
FINNHUB_API_KEY=your_finnhub_api_key

# Schedule (cron-like: day_of_week hour minute)
SCHEDULE_DAYS=mon,wed,fri
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0

# Analysis thresholds
MAX_PRICE=200
MIN_DRAWDOWN=-15
MIN_COMPOSITE_SCORE=55
TOP_PICKS_COUNT=7
PRE_FILTER_RSI=40

# Logging
LOG_LEVEL=INFO
